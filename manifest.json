{
  "manifest_version": 3,
  "name": "Med's Extension",
  "version": "1.1.0",
  "description": "A stunning new tab bookmark manager with custom wallpapers and categorized bookmarks.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "bookmarks"
  ],
  "host_permissions": [
    "https://www.google.com/s2/favicons*",
    "https://icons.duckduckgo.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Chrome Bookmarks"
  }
}
